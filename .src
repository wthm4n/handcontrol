version = 2

[project]
name = "hand-control"
root = "."
ignore_pm = true

[ollama]
enabled = true
model = "llama3.2:3b"

[watcher]
enabled = true

[formatter]
enabled = true
auto_format = true

[git]
enabled = true
branch = "handctrl"
remote = "origin"

auto_commit = true
auto_push = true

commit_message = "auto: update"

[tasks]
default = "sync"