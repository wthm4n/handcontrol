version = 2

[project]
name = "hand-control"
root = "."
ignore_pm = true

[ollama]
enabled = true
model = "qwen2.5-coder:7b-instruct-q4_K_M"

[watcher]
enabled = true

[formatter]
enabled = true
auto_format = true

[git]
enabled = true
branch = "handctrl"
remote = "origin"

auto_commit = true
auto_push = true

commit_message = "auto: update"

[tasks]
default = "sync"